{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vizzy",
  "version": "0.1.0",
  "identifier": "com.driptap.vizzy",
  "build": {
    "beforeDevCommand": "npm run dev:renderer",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vizzy",
        "width": 1480,
        "height": 940,
        "minWidth": 1100,
        "minHeight": 720,
        "backgroundColor": "#0a0a0a"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis", "appimage", "deb"],
    "category": "Music",
    "macOS": {
      "frameworks": ["vendor/Syphon.framework"]
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["vizzy"],
        "name": "Vizzy Workspace",
        "description": "Vizzy workspace bundle",
        "role": "Editor",
        "mimeType": "application/vnd.vizzy.workspace"
      }
    ],
    "resources": {
      "icons/vizzy-document.icns": "vizzy-document.icns"
    }
  }
}
