{
  "name": "prompt-vj",
  "version": "0.1.0",
  "description": "Live VJ tool: LLM-generated GLSL shaders, 4-deck mixer, audio-reactive, MIDI-controlled",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "vite build",
    "start": "npm run build && electron .",
    "preview": "vite preview",
    "model:pull": "ollama pull qwen2.5-coder"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "^38.0.0",
    "tailwindcss": "^4.1.0",
    "vite": "^7.1.0",
    "wait-on": "^8.0.1"
  }
}
